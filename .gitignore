.idea/
*.sln.iml

# ReSharper (can be created by VS/Rider)
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# .NET tool caches
.dotnet/
project.lock.json
project.fragment.lock.json

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/

# Test results / coverage
TestResults/
coverage/
*.coverage
*.coveragexml
coverage.cobertura.xml
coverage.opencover.xml

# ASP.NET / IIS
**/[Aa]pp_[Dd]ata/
**/[Ll]ogs/

# Publish output
**/publish/

# Environment / local overrides
.env
.env.*
!.env.example

# Keep appsettings.json committed; ignore machine/local overrides
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

